<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.globalfx.trade.mapper.PositionMapper">

    <select id="selectByAccountIdWithSymbol" resultType="com.globalfx.trade.entity.Position">
        SELECT p.*
        FROM pos_position p
        WHERE p.account_id = #{accountId}
          AND p.is_deleted = 0
        ORDER BY p.open_time DESC
    </select>

</mapper>
